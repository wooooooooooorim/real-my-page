    <h2 style="text-align: center;">[ 과제 9장 자바스크립트 결과 ]</h2>
    <div class="js-result-box">
        <script>
            let cm = prompt("16번문제 : 인치와 피트로 변환하기 (cm 입력)");
            let totalInch = cm / 2.54;
            let feet = Math.floor(totalInch / 12);
            let inch = totalInch % 12;

            document.write("<h3>16번 결과</h3>");
            document.write(cm + "cm는 " + feet + "피트, " + inch.toFixed(2) + "인치입니다.<br>");
            document.write("<hr>");

            let r = prompt("17번 : 원기둥의 반지름 길이 입력");
            let h = prompt("17번: 원기둥의 높이 입력");
            let pi = 3.14;  
            let volume = r * r * pi * h;

            document.write("<h3>17번 결과</h3>");
            document.write("반지름 " + r + ", 높이 " + h + "인 원기둥의 부피: " + volume + "<br>");
            document.write("<hr>");

            let inputNum = prompt("18번 : 네 자리의 정수값 입력", "1234");
            let num = parseInt(inputNum);

            let chunk1000 = Math.floor(num / 1000);
            let chunk100 = Math.floor((num % 1000) / 100);
            let chunk10 = Math.floor((num % 100) / 10);
            let chunk1 = num % 10;

            document.write("<h3>18번 결과</h3>");
            document.write("입력한 숫자: " + num + "<br>");
            document.write("천의 자리: " + chunk1000 + ", 백의 자리: " + chunk100 + ", 십의 자리: " + chunk10 + ", 일의 자리: " + chunk1);
        </script>
    </div>

